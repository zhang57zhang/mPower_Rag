## 🔧 高级功能

### 1. 缓存装饰器

```python
from core.utils.cache import cache_decorator, get_cache
from config.settings import settings

# 获取缓存实例
cache = get_cache(settings.model_dump())

# 使用装饰器
@cache_decorator(cache, prefix="custom", ttl=3600)
def expensive_function(query: str) -> str:
    """耗时的函数"""
    # 模拟耗时操作
    import time
    time.sleep(2)
    return f"Result for {query}"
```

### 2. 自定义缓存键

```python
def custom_key_generator(*args, **kwargs) -> str:
    """自定义缓存键生成器"""
    # 提取特定参数作为键
    query = kwargs.get("query", "")
    top_k = kwargs.get("top_k", 5)

    # 生成键
    key_str = f"{query}:{top_k}"

    return key_str

# 使用自定义键生成器
@cache_decorator(
    cache,
    prefix="custom",
    ttl=3600,
    key_func=custom_key_generator
)
def custom_cache_function(query: str, top_k: int = 5) -> str:
    """使用自定义键的函数"""
    return f"Result (top_k={top_k}) for {query}"
```

### 3. 条件缓存

```python
@cache_decorator(cache, prefix="conditional", ttl=3600)
def conditional_cache_function(query: str, use_cache: bool = True) -> str:
    """条件缓存函数"""
    if not use_cache:
        # 标记跳过缓存（可以通过 kwargs 传递）
        return {"skip_cache": True}  # 实际逻辑需要在装饰器中实现

    return f"Result for {query}"
```

