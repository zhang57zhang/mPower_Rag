## 🎨 前端集成

### Streamlit 集成

```python
import streamlit as st
import requests

# 缓存统计面板
st.sidebar.markdown("### 🚀 缓存状态")

# 获取缓存统计
response = requests.get("http://localhost:8000/api/v1/cache/stats", timeout=10)

if response.status_code == 200:
    stats = response.json()

    # 显示缓存状态
    if stats.get("connected"):
        st.success("✅ Redis 已连接")
        st.metric("总键数", stats.get("total_keys", 0))

        # 显示各前缀的键数
        prefix_counts = stats.get("prefix_counts", {})
        if prefix_counts:
            st.write("**各前缀键数**:")
            for prefix, count in prefix_counts.items():
                st.write(f"- {prefix}: {count} 个")
    else:
        st.error("❌ Redis 未连接")

    # 清空缓存按钮
    col1, col2 = st.sidebar.columns(2)

    with col1:
        if st.button("清空所有缓存"):
            response = requests.post(
                "http://localhost:8000/api/v1/cache/clear_all",
                timeout=10,
            )
            if response.status_code == 200:
                st.success("✅ 缓存已清空")
                st.rerun()
            else:
                st.error("❌ 清空失败")

    with col2:
        # 选择前缀清空
        prefix_to_clear = st.selectbox(
            "清空前缀",
            options=["", "query", "retrieval", "llm", "rerank"]
        )

        if st.button(f"清空前缀 {prefix_to_clear}") and prefix_to_clear:
            response = requests.post(
                "http://localhost:8000/api/v1/cache/clear",
                json={"prefix": prefix_to_clear},
                timeout=10,
            )
            if response.status_code == 200:
                st.success(f"✅ 已清空前缀 {prefix_to_clear}")
                st.rerun()
            else:
                st.error("❌ 清空失败")
else:
    st.warning("无法获取缓存统计")
```

