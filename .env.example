# Production环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ====================
# LLM配置
# ====================
# DeepSeek API密钥（必需）
LLM_API_KEY=your_deepseek_api_key_here

# LLM API地址（可选，默认：https://api.deepseek.com）
LLM_BASE_URL=https://api.deepseek.com

# LLM模型（可选，默认：deepseek-chat）
LLM_MODEL=deepseek-chat

# ====================
# 向量数据库配置
# ====================
# Qdrant主机（可选，默认：qdrant for Docker, localhost for local）
QDRANT_HOST=localhost

# Qdrant端口（可选，默认：6333）
QDRANT_PORT=6333

# ====================
# 应用配置
# ====================
# API端口（可选，默认：8000）
API_PORT=8000

# API主机（可选，默认：0.0.0.0）
API_HOST=0.0.0.0

# 日志级别（可选，默认：INFO）
LOG_LEVEL=INFO

# 调试模式（可选，默认：false）
DEBUG=false

# ====================
# 安全配置
# ====================
# API 认证开关（生产环境建议启用）
API_AUTH_ENABLED=false

# API Keys（逗号分隔，生产环境必须设置）
# 示例：API_KEYS=mpower_key1,mpower_key2
API_KEYS=

# 管理员 API Keys（逗号分隔）
ADMIN_API_KEYS=

# CORS 允许的域名（逗号分隔，生产环境必须设置具体域名）
# 示例：CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# 输入限制
MAX_CONTENT_LENGTH=10485760
MAX_QUERY_LENGTH=10000

# ====================
# 缓存配置
# ====================
# 缓存开关
CACHE_ENABLED=false

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 或使用完整 URL
# REDIS_URL=redis://:password@localhost:6379/0

# 缓存 TTL（秒）
CACHE_TTL=3600

# ====================
# 监控配置
# ====================
# Prometheus 开关
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana管理员密码（可选，默认：admin）
GRAFANA_PASSWORD=admin

# ====================
# Docker配置（仅Docker环境）
# ====================
# Docker Compose项目名称（可选）
COMPOSE_PROJECT_NAME=mpower-rag
