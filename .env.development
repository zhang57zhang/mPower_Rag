# mPower_Rag 开发环境配置
# 创建时间: 2026-03-10
# 说明: 开发环境专用配置，方便调试

# ====================
# 应用基础配置
# ====================
APP_NAME=mPower_Rag_Dev
APP_VERSION=1.0.0-dev
DEBUG=true
LOG_LEVEL=DEBUG

# ====================
# API 配置
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ====================
# LLM 配置
# ====================
LLM_API_KEY=sk-placeholder-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ====================
# 向量数据库配置
# ====================
VECTOR_DB_TYPE=chroma
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=vehicle_test_knowledge_dev

# ====================
# RAG 配置
# ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.6

# ====================
# 重排序配置
# ====================
RERANK_ENABLED=false
RERANK_METHOD=cross_encoder
RERANK_MODEL=BAAI/bge-reranker-base

# ====================
# 缓存配置（开发环境禁用）
# ====================
CACHE_ENABLED=false
CACHE_TYPE=memory
CACHE_TTL=300

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ====================
# 安全配置（开发环境宽松）
# ====================

# API 认证（开发环境可以禁用）
API_AUTH_ENABLED=false

# API Keys（开发环境使用测试 Key）
API_KEYS=dev_test_key_1,dev_test_key_2
ADMIN_API_KEYS=dev_admin_key

# CORS 配置（开发环境允许所有）
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# 限流配置（开发环境宽松）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST_SIZE=100

# 输入限制
MAX_CONTENT_LENGTH=52428800  # 50MB（开发环境放宽）
MAX_QUERY_LENGTH=50000

# ====================
# 监控配置
# ====================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ====================
# 日志配置
# ====================
LOG_FILE=./logs/app-dev.log
LOG_LEVEL=DEBUG

# ====================
# 文档存储路径
# ====================
KNOWLEDGE_BASE_PATH=./knowledge_base
DOCUMENTS_PATH=./knowledge_base/documents
PARSED_DATA_PATH=./knowledge_base/parsed

# ====================
# 性能配置
# ====================
WORKERS=1  # 开发环境单进程

# 超时配置
API_TIMEOUT=60
VECTOR_SEARCH_TIMEOUT=30
LLM_TIMEOUT=120

# ====================
# Docker 配置
# ====================
COMPOSE_PROJECT_NAME=mpower-rag-dev
