# mPower_Rag 生产环境配置
# 创建时间: 2026-03-10
# 说明: 生产环境专用配置，包含安全默认值

# ====================
# 应用基础配置
# ====================
APP_NAME=mPower_Rag
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ====================
# API 配置
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ====================
# LLM 配置
# ====================
# 生产环境必须配置有效的 API Key
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ====================
# 向量数据库配置
# ====================
VECTOR_DB_TYPE=qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=vehicle_test_knowledge
# QDRANT_API_KEY=  # 如需认证

# ====================
# RAG 配置
# ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.6

# ====================
# 重排序配置
# ====================
RERANK_ENABLED=true
RERANK_METHOD=cross_encoder
RERANK_MODEL=BAAI/bge-reranker-base

# ====================
# 缓存配置（生产环境推荐启用）
# ====================
CACHE_ENABLED=true
CACHE_TYPE=redis
CACHE_TTL=3600

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 如需认证
# REDIS_URL=redis://:password@redis:6379/0

# ====================
# 安全配置（生产环境必须配置）
# ====================

# API 认证（生产环境必须启用）
API_AUTH_ENABLED=true

# API Keys（必须设置，逗号分隔）
# 示例：API_KEYS=mpower_prod_key1,mpower_prod_key2
API_KEYS=your_production_api_key_1,your_production_api_key_2

# 管理员 API Keys
ADMIN_API_KEYS=your_admin_api_key_1

# CORS 配置（生产环境必须设置具体域名）
# 示例：CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://your-domain.com
CORS_ALLOW_CREDENTIALS=true

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# 输入限制
MAX_CONTENT_LENGTH=10485760  # 10MB
MAX_QUERY_LENGTH=10000

# ====================
# 监控配置（生产环境推荐启用）
# ====================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana 配置
GRAFANA_PASSWORD=change_this_password

# ====================
# 日志配置
# ====================
LOG_FILE=/app/logs/app.log
LOG_LEVEL=INFO

# ====================
# 文档存储路径
# ====================
KNOWLEDGE_BASE_PATH=/app/knowledge_base
DOCUMENTS_PATH=/app/knowledge_base/documents
PARSED_DATA_PATH=/app/knowledge_base/parsed

# ====================
# 性能配置
# ====================
# 工作进程数（建议设置为 CPU 核心数 * 2 + 1）
WORKERS=4

# 超时配置
API_TIMEOUT=30
VECTOR_SEARCH_TIMEOUT=10
LLM_TIMEOUT=60

# ====================
# Docker 配置
# ====================
COMPOSE_PROJECT_NAME=mpower-rag-prod

# ====================
# 备份配置
# ====================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24小时
BACKUP_RETENTION=7  # 保留7天

# ====================
# 邮件通知（可选）
# ====================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
# ALERT_EMAIL=admin@example.com
